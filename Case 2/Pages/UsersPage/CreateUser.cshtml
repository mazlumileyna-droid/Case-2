@page
@model Case_2.Pages.UsersPage.CreateUserModel
@{
}


<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm">
        
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">➕ Opret bruger</h5>
        </div>

        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form method="post">

                <!-- Navn -->
                <div class="mb-3">
                    <label class="form-label">Navn</label>
                    <input asp-for="User.Name" class="form-control" required />
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="User.Email" class="form-control" required />
                    <small class="text-muted">
                        Studerende: @@edu.zealand.dk | Undervisere: @@zealand.dk
                    </small>
                </div>

                <!-- Adgangskode -->
                <div class="mb-3">
                    <label class="form-label">Adgangskode</label>
                    <input asp-for="User.Password" class="form-control" required />
                </div>

                <!-- Rolle -->
                <div class="mb-3">
                    <label class="form-label">Rolle</label>
                    <select asp-for="User.Role" class="form-select">
                        <option value="Student">Studerende</option>
                        <option value="Teacher">Underviser</option>
                        <option value="Admin">Administrator</option>
                    </select>
                </div>

                <!-- Knapper -->
                <div class="d-flex justify-content-between">
                    <a asp-page="/UsersPage/GetAllUsers" class="btn btn-secondary">
                        Annuller
                    </a>

                    <button type="submit" class="btn btn-success">
                        Opret
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>