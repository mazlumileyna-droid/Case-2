@page
@model Case_2.Pages.UsersPage.GetAllUsersModel
@using Case_2.Models
@{
}


<h2 class="mb-3">
    @if (User.IsInRole("Admin"))
    {
        <text>Alle brugere</text>
    }
    else if (User.IsInRole("Teacher"))
    {
        <text>Studerende</text>
    }
</h2>

<table class="table table-hover align-middle text-center shadow-sm">

    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Navn</th>
            <th>Email</th>
            <th>Rolle</th>
            <th>Handlinger</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Users != null && Model.Users.Any())
        {
            foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge 
                            @(user.Role == Role.Admin ? "bg-danger" :
                              user.Role == Role.Teacher ? "bg-primary" :
                              "bg-success")">
                            @user.Role
                        </span>
                    </td>

                    <td>
                        <div class="d-flex flex-column flex-md-row gap-2 justify-content-center">
                            
                            <a class="btn btn-warning btn-sm"
                               asp-page="/UsersPage/EditUser"
                               asp-route-id="@user.UserId">
                                ✏️ Rediger
                            </a>

                            <a class="btn btn-danger btn-sm"
                               asp-page="/UsersPage/DeleteUser"
                               asp-route-id="@user.UserId">
                                🗑 Slet
                            </a>

                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5">Ingen brugere fundet</td>
            </tr>
        }
    </tbody>

</table>

<div class="mt-3">
    <a asp-page="/UsersPage/LogInPage/AdminDashBoard" class="btn btn-secondary">
        ← Tilbage
    </a>
</div>